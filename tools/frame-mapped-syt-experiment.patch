+        model.Configure(TxTimingModel::Config{});
+        const int64_t anchorFrame0 = Timing::normalizeOffsetDomain(recovered - 48 * 512);
+        const auto decision = model.PeekNextDataSyt(anchorFrame0, cadence, 0);
+        ASSERT_NE(decision.syt, 0xFFFF);
+        EXPECT_EQ(model.OutputPhaseTicks(), anchorFrame0);
+    }
+
+    // Test 2: TX asks for phase at frame 48. Expected: RX phase exactly.
+    {
+        TxTimingModel model{};
+        model.Configure(TxTimingModel::Config{});
+        const int64_t anchorFrame48 = recovered;
+        const auto decision = model.PeekNextDataSyt(anchorFrame48, cadence, 48);
+        ASSERT_NE(decision.syt, 0xFFFF);
+        EXPECT_EQ(model.OutputPhaseTicks(), anchorFrame48);
+    }
+}
+
+TEST(TxTimingModelTests, SeedingDoesNotSnapRxPhaseToExecutionAnchor) {
+    RxSytCadence cadence{};
+    cadence.Reset();
+
+    constexpr int64_t rxPhase = 100'000;
+    const int64_t firstPhase =
+        rxPhase - static_cast<int64_t>(RxSytCadence::kWarmupUpdates - 1) *
+        Timing::kSytPacketStepTicks48k;
+
+    int64_t phase = firstPhase;
+    for (uint32_t i = 0; i < RxSytCadence::kWarmupUpdates; ++i) {
+        const int64_t packetCycle = phase - Timing::kTicksPerCycle;
+        const uint64_t frameCursor =
+            (i == RxSytCadence::kWarmupUpdates - 1) ? 48 : 0;
+
+        EXPECT_TRUE(cadence.Observe(
+            SytFromTicks(phase),
+            CycleTimerFromTicks(packetCycle),
+            frameCursor));
+
+        phase += Timing::kSytPacketStepTicks48k;
+    }
+
+    const int64_t recovered = Timing::normalizeOffsetDomain(
+        phase - Timing::kSytPacketStepTicks48k);
+
+    const int64_t expectedFrame0 =
+        Timing::normalizeOffsetDomain(recovered - 48 * 512);
+
+    const int64_t misleadingExecutionAnchor =
+        Timing::normalizeOffsetDomain(expectedFrame0 + 15 * 512);
+
+    TxTimingModel model{};
+    model.Configure(TxTimingModel::Config{});
+
+    const auto decision =
+        model.PeekNextDataSyt(misleadingExecutionAnchor, cadence, 0);
+
+    ASSERT_NE(decision.syt, 0xFFFF);
+
+    EXPECT_EQ(model.OutputPhaseTicks(), expectedFrame0);
+}
